# Elasticsearch Connection
ES_HOST = "https://localhost:9200"
ES_USER = "elastic"
ES_PASS = "..."

# Elasticsearch Ingestion
ENABLE_ES_INGEST = True
RESULTS_INDEX = anomaly-predictions

# Future Prediction
PREDICT_FUTURE_DAYS = 7

# Field mapping and query
INDEX_PATTERN = "logs*"
OUTPUT_DIR = "./alerts_plots"
TIMESTAMP_FIELD = @timestamp
GRAIN_FIELD = "dest_host"  # Use 'host.name' for syslogs, 'src_ip' for firewall, etc.
ANALYSIS_START = "now-30d"
ANALYSIS_END = "now-1h"
FIXED_INTERVAL = "1h"
AGG_SIZE = 200

# Alert Tuning
MIN_DOCS = 150000
BUFFER_PERCENT = 1.20  # 1.20 = 20% buffer above the Max_Threshold
INTERVAL_WIDTH = 0.99  # Larger number less sensitivity
MINIMUM_SAMPLES = 168  # Minimum amount of samples required to process (168 hours in a week)

# Alert Plotting Toggles
GENERATE_PLOTS = False
PLOT_UPPER_ALERTS = True
PLOT_LOWER_ALERTS = False
